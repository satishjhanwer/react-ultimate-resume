    "projects": [
        {
            "id": "4c362cf5-7948-4c92-b362-bf60793ff898",
            "name": "Borrower Portal (Product)",
            "description": "We have built a product named as Borrower Portal, This portal creates a way for end-user to apply for a loan. Which includes various steps likes uploading required government documents which help to process the loan application. Provide a way to link end-users bank account which ensures applied loan money deposited into bank account electronically. This uses services like plain / fincity.",
            "endDate": "2018-12-01",
            "index": 0
        },
        {
            "id": "61b4038b-2e61-49ec-99a4-ad17adc9f928",
            "name": "Back-Office Portal (Product)",
            "description": "We have built a product named as Back-Office Portal, Which handles loan application, with the various life cycle of loan application and executes various steps including verification using 3rd party providers, generating cash flow and creating reports based on it.",
            "endDate": "2018-12-01",
            "index": 1
        },
        {
            "name": "Customer Facing and Back-Office Portal",
            "description": "We created a customer and back-office portal for one of the biggest personal loan provider in USA. Which has various process which are required for a loan application to move further in its lifecycle.",
            "endDate": "2016-03-31",
            "index": 2
        },
        {
            "id": "de55013f-1c9a-4603-b698-44b1810ad69c",
            "name": "SAAS based Application for Manufactures",
            "description": "Its a high-performance, multi-tenant cloud application. It’s a SAAS based solution for Sales/Marketing team for the Consumer Products industry, that sell products to the retailers.",
            "endDate": "2014-03-31",
            "index": 3
        },
        {
            "id": "1e3a2796-e06c-4322-96ca-0df39c478d8d",
            "name": "SAAS Application based on Social Domain",
            "description": "The Social Business Index (SBI) is used to score and rank social network activity about various large MNC's, across the top social networks, including Twitter, LinkedIn and Facebook. Based on the followers of these social networks of various companies, the software arrives at a score (Business Index) and ranks it as per highest to lowest. Each of the products of these companies will be segmented and find the score ratio which will be used for analysis, recommendations and to generate analytical reports, charts etc",
            "endDate": "2013-12-01",
            "index": 4
        },
        {
            "id": "09fa39da-9153-4289-b992-b2a2c8938693",
            "name": "SAAS based Application for Tracking Brand’s Social Performance",
            "description": "It is a SAAS web application that tracks the brand’s social activities against brand marketing business outcomes including Brand Awareness, Brand Love, Brand Mindshare, and Brand Advocacy. Unlike alternatives that focus only on simplistic activity counts, it provides metrics correlated to the brand marketing business outcomes and benchmarked against the competitors and industry.",
            "endDate": "2012-12-01",
            "index": 5
        },
        {
            "id": "7bcc6b3c-9399-41d7-ba70-0070e7e42c0f",
            "name": "SAAS for Brand’s Advocacy Impact",
            "description": "It is a subscription service that identifies a brand’s top advocates across social channels and measures brand impact, giving a more scalable (and trusted) way of engaging with the audience. It identifies a brand’s advocates by isolating brand-related conversations and applying sentiment and topic analysis, creating a unique window into the people and conversations that reinforce a brand’s message in the market.",
            "endDate": "2012-12-01",
            "index": 6
        },
        {
            "id": "40033a45-d6f9-4d2a-bf1e-deb6a043221e",
            "name": "SAAS for managing Employees’ Social Advocacy",
            "description": "It is a subscription service that measures the impact of employees’ social activities on a brand and allows for the management of employee advocacy programs, giving brands the ability to scale their engagement across their social audience. Brands can mobilize and measure their employees' social efforts with a Portal and an Employee Leader board, enabling to showcase policies and programs, and providing with insight to posts, followers, sentiment, and echoed signals.",
            "endDate": "2011-12-01",
            "index": 7
        }
